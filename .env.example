# PostgreSQL admin / superuser (used by the postgres service and init scripts)
POSTGRES_USER=postgres
POSTGRES_PASSWORD=changeme
POSTGRES_DB=graphdb

# Read-only user (used by the backend application)
PG_READONLY_USER=readonly
PG_READONLY_PASSWORD=changeme_readonly

# psycopg2-style connection string for the backend.
# Use localhost:5432 when connecting from outside Docker (e.g. local dev tools).
# Use postgres:5432 when the backend runs as a sibling Docker Compose service.
DATABASE_URL=postgresql://readonly:changeme_readonly@localhost:5432/graphdb
